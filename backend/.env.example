# ============================================
# SERVEUR
# ============================================
PORT=5500
NODE_ENV=development

# URL du frontend — utilisée pour la configuration CORS
# En développement : http://localhost:5173 (Vite)
# En production : https://votre-app.vercel.app
FRONTEND_URL=http://localhost:5173

# ============================================
# BASE DE DONNÉES POSTGRESQL
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=memoria_db
DB_USER=votre_user_postgres
DB_PASSWORD=votre_mot_de_passe

# En production (Render/Railway) : remplacer les variables ci-dessus par :
# DATABASE_URL=postgresql://user:password@host:5432/memoria_db

# ============================================
# JWT (Authentification)
# ============================================
JWT_SECRET=generer_une_cle_secrete_longue_et_aleatoire_minimum_32_caracteres
JWT_EXPIRES_IN=24h

# ============================================
# CLOUDINARY (Upload photos)
# ============================================
CLOUDINARY_CLOUD_NAME=votre_cloud_name
CLOUDINARY_API_KEY=votre_api_key
CLOUDINARY_API_SECRET=votre_api_secret

# ============================================
# STRIPE (Paiements - MODE TEST UNIQUEMENT)
# ============================================
STRIPE_SECRET_KEY=sk_test_votre_cle
STRIPE_PUBLISHABLE_KEY=pk_test_votre_cle

# Webhook Stripe — requis pour valider les événements en production
# Générer avec : stripe listen --print-secret
STRIPE_WEBHOOK_SECRET=whsec_votre_secret

# ============================================
# GOOGLE MAPS (Géocodage cimetières)
# ============================================
GOOGLE_MAPS_API_KEY=votre_api_key

# ============================================
# API TWILIO ( Envoie de sms pour récupèration du mots de passe)
# ============================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX